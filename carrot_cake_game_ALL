<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Carrot Cake Catcher 🥕</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Fredoka+One&family=Nunito:wght@400;700;800&display=swap');

  :root {
    --cream: #f5e6c8;
    --frosting: #fdf6e3;
    --carrot: #e8722a;
    --carrot-dark: #c45a18;
    --green: #4a7c2f;
    --cake-brown: #a06b3c;
    --walnut: #6b4226;
    --bg: #fff8ee;
    --shadow: rgba(100,60,20,0.18);
  }
  body.dark-mode {
    --cream: #3a2e22;
    --frosting: #2b2018;
    --carrot: #ff9a4d;
    --carrot-dark: #ffb877;
    --green: #7fbf5a;
    --cake-brown: #6b4a30;
    --walnut: #f0e0c8;
    --bg: #14100c;
    --shadow: rgba(0,0,0,0.5);
  }

  * { margin:0; padding:0; box-sizing:border-box; }

  body {
    background: var(--bg);
    font-family: 'Nunito', sans-serif;
    display: flex; flex-direction: column; align-items: center;
    min-height: 100vh; overflow: hidden;
    background-image:
      radial-gradient(circle at 20% 20%, #ffe4b5 0%, transparent 50%),
      radial-gradient(circle at 80% 80%, #ffd580 0%, transparent 50%);
  }

  h1 {
    font-family: 'Fredoka One', cursive;
    color: var(--carrot-dark);
    font-size: clamp(1.4rem, 4vw, 2.2rem);
    margin: 10px 0 4px;
    letter-spacing: 1px;
    text-shadow: 3px 3px 0 #f5e6c8, 5px 5px 0 rgba(200,100,30,0.15);
  }

  #hud {
    display: flex; gap: 8px; margin-bottom: 6px;
    align-items: center; flex-wrap: wrap; justify-content: center;
  }
  @keyframes cakeAuraPulse {
    0%,100% { opacity:0.5;  transform:translate(-50%,-50%) scale(1);   }
    50%     { opacity:0.85; transform:translate(-50%,-50%) scale(1.18);}
  }
  .cake-aura {
    position:absolute; left:50%; top:50%; width:80px; height:80px; border-radius:50%;
    pointer-events:none; z-index:-1; filter:blur(12px);
    animation:cakeAuraPulse 1.8s ease-in-out infinite;
  }
  .hud-box {
    background: var(--frosting); border: 3px solid var(--cake-brown);
    border-radius: 16px; padding: 3px 12px;
    font-size: 0.95rem; font-weight: 800; color: var(--walnut);
    box-shadow: 3px 3px 0 var(--cake-brown);
  }
  .hud-box span { color: var(--carrot); }
  #mode-badge { background: var(--green); color:#fff; border-color:#2d5a1a; box-shadow:3px 3px 0 #2d5a1a; }

  /* Top nav buttons */
  #top-nav { display:flex; gap:8px; margin-bottom:4px; }
  .nav-btn {
    font-family:'Fredoka One',cursive; font-size:0.85rem;
    background: var(--frosting); color: var(--walnut);
    border: 2px solid var(--cake-brown); border-radius:20px;
    padding: 3px 14px; cursor:pointer;
    box-shadow:2px 2px 0 var(--cake-brown); transition:transform 0.1s;
  }
  .nav-btn:hover { transform:translateY(-2px); }
  .nav-btn.active { background:var(--carrot); color:#fff; border-color:var(--carrot-dark); box-shadow:2px 2px 0 var(--carrot-dark); }

  /* ── Game Area ── */
  #game-area {
    position: relative; width: min(480px, 96vw); height: 490px;
    background: linear-gradient(180deg, #ffe8b0 0%, #ffd580 60%, #f0c060 100%);
    border: 4px solid var(--cake-brown); border-radius: 24px; overflow: hidden;
    box-shadow: 0 8px 32px var(--shadow), inset 0 2px 8px rgba(255,255,255,0.6);
    cursor: none; transition: background 0.8s;
  }
  /* Restore cursor on overlays and interactive children */
  #overlay, #overlay *, #badges-panel, #badges-panel *, #name-prompt, #name-prompt *, #shop-panel, #shop-panel * { cursor: default; }
  #overlay button, #overlay .mode-card,
  #badges-panel button, #badges-panel .badge-circle { cursor: pointer; }
  #game-area.mode-blitz     { background: linear-gradient(180deg,#ff6b35 0%,#ff9a3c 60%,#ffb347 100%); }
  #game-area.mode-zen       { background: linear-gradient(180deg,#b8e4f9 0%,#d4f5c4 60%,#e8f5b0 100%); }
  #game-area.mode-nightmare { background: linear-gradient(180deg,#1a0a2e 0%,#2d1b4e 60%,#1a0a2e 100%); }
  #game-area.mode-reversed  { background: linear-gradient(180deg,#2e0a4e 0%,#4e1a7e 60%,#2e0a4e 100%); }
  #game-area.mode-golden    { background: linear-gradient(180deg,#fff176 0%,#ffd700 60%,#ffaa00 100%); }
  #game-area.mode-easter    { background: linear-gradient(180deg,#b8f0e0 0%,#ffe8f0 50%,#fff8e0 100%); }
  #game-area.mode-chaos     { background: linear-gradient(180deg,#2d0a40 0%,#800080 40%,#c00030 100%); }
  #game-area.mode-precision { background: linear-gradient(180deg,#0a1a3a 0%,#1a3a6a 60%,#0a2050 100%); }

  #game-area::after {
    content:''; position:absolute; bottom:0; left:0; right:0; height:56px;
    background: repeating-linear-gradient(90deg,#a06b3c 0,#a06b3c 18px,#8a5530 18px,#8a5530 36px);
    border-top:4px solid var(--walnut); border-radius:0 0 20px 20px;
  }
  #game-area.mode-nightmare::after {
    background: repeating-linear-gradient(90deg,#3a1a5e 0,#3a1a5e 18px,#2a0a4e 18px,#2a0a4e 36px);
    border-top-color:#1a0a2e;
  }

  .item {
    position:absolute; width:40px; height:40px;
    display:flex; align-items:center; justify-content:center;
    font-size:28px; filter:drop-shadow(2px 3px 3px rgba(0,0,0,0.18));
    user-select:none; pointer-events:none;
  }

  #basket { position:absolute; bottom:58px; left:50%; transform:translateX(-50%); width:80px; height:54px; pointer-events:none; z-index:10; transition:width 0.3s; }
  #score-popup { position:absolute; font-family:'Fredoka One',cursive; font-size:1.5rem; color:var(--carrot); pointer-events:none; opacity:0; transition:opacity 0.3s; text-shadow:1px 1px 0 #fff; z-index:20; }
  #timer-bar-wrap { position:absolute; top:8px; left:12px; right:12px; height:10px; background:rgba(0,0,0,0.15); border-radius:10px; z-index:20; display:none; }
  #timer-bar { height:100%; background:linear-gradient(90deg,var(--carrot),#f5d020); border-radius:10px; width:100%; transition:background 0.3s; }
  #combo-display { position:absolute; top:26px; left:12px; font-family:'Fredoka One',cursive; font-size:1.1rem; color:#fff; text-shadow:2px 2px 0 rgba(0,0,0,0.3); z-index:20; opacity:0; transition:opacity 0.3s; }
  #level-badge { position:absolute; top:8px; right:10px; font-family:'Fredoka One',cursive; font-size:0.9rem; background:#f06aab; color:#fff; border-radius:20px; padding:2px 10px; box-shadow:2px 2px 0 #b8447f; z-index:20; }
  #powerup-msg { position:absolute; bottom:120px; left:50%; transform:translateX(-50%); font-family:'Fredoka One',cursive; font-size:1rem; color:#fff; background:rgba(0,0,0,0.45); border-radius:20px; padding:4px 16px; z-index:20; opacity:0; pointer-events:none; transition:opacity 0.4s; white-space:nowrap; }
  #particles-container { position:absolute; inset:0; pointer-events:none; z-index:15; }
  .particle { position:absolute; width:8px; height:8px; border-radius:50%; pointer-events:none; }

  /* ── Badge unlock toast ── */
  #badge-toast {
    position:absolute; bottom:80px; left:50%; transform:translateX(-50%);
    background: linear-gradient(135deg,#fff8ee,#ffecc0);
    border: 3px solid var(--carrot); border-radius:20px;
    padding: 10px 18px; z-index:30; display:flex; align-items:center; gap:10px;
    box-shadow:0 4px 20px rgba(200,100,30,0.35); white-space:nowrap;
    opacity:0; pointer-events:none; transition:opacity 0.4s;
  }
  #badge-toast .toast-icon { font-size:2rem; }
  #badge-toast .toast-text { font-family:'Fredoka One',cursive; }
  #badge-toast .toast-title { font-size:0.75rem; color:var(--walnut); }
  #badge-toast .toast-name  { font-size:1rem; color:var(--carrot-dark); }

  /* ── Overlay ── */
  #overlay {
    position:absolute; inset:0; background:rgba(255,240,200,0.96);
    display:flex; flex-direction:column; align-items:center; justify-content:flex-start;
    padding:14px 12px; gap:9px; z-index:50; border-radius:20px; overflow-y:auto;
  }
  #overlay h2 { font-family:'Fredoka One',cursive; font-size:1.9rem; color:var(--carrot-dark); text-shadow:3px 3px 0 #f5e6c8; }
  #overlay .big-emoji { font-size:3rem; animation:bounce 0.7s infinite alternate; }
  @keyframes bounce { from{transform:translateY(0)} to{transform:translateY(-12px)} }

  .mode-grid { display:grid; grid-template-columns:1fr 1fr; gap:8px; width:100%; }
  .mode-card {
    background:var(--frosting); border:3px solid var(--cake-brown);
    border-radius:16px; padding:10px 8px; cursor:pointer; text-align:center;
    transition:transform 0.15s,box-shadow 0.15s,border-color 0.15s;
    box-shadow:3px 3px 0 var(--cake-brown); user-select:none;
  }
  .mode-card:hover  { transform:translateY(-3px); box-shadow:3px 6px 0 var(--cake-brown); }
  .mode-card:active { transform:translateY(1px);  box-shadow:1px 1px 0 var(--cake-brown); }
  .mode-card.selected { border-color:var(--carrot); box-shadow:3px 3px 0 var(--carrot); background:#fff3e0; }
  .mode-card .mode-icon { font-size:1.8rem; }
  .mode-card .mode-name { font-family:'Fredoka One',cursive; font-size:1rem; color:var(--carrot-dark); margin:2px 0; }
  .mode-card .mode-desc { font-size:0.66rem; color:var(--walnut); font-weight:700; line-height:1.3; }

  button.play-btn {
    font-family:'Fredoka One',cursive; font-size:1.2rem;
    background:var(--carrot); color:#fff; border:none;
    border-radius:50px; padding:9px 36px; cursor:pointer;
    box-shadow:0 4px 0 var(--carrot-dark); transition:transform 0.1s,box-shadow 0.1s; width:100%;
  }
  button.play-btn:hover  { transform:translateY(-2px); box-shadow:0 6px 0 var(--carrot-dark); }
  button.play-btn:active { transform:translateY(2px);  box-shadow:0 2px 0 var(--carrot-dark); }

  button.small-btn {
    font-family:'Fredoka One',cursive; font-size:0.95rem;
    background:var(--cake-brown); color:#fff; border:none;
    border-radius:50px; padding:6px 20px; cursor:pointer;
    box-shadow:0 3px 0 var(--walnut); transition:transform 0.1s;
  }
  button.small-btn:hover { transform:translateY(-2px); }

  .legend { font-size:0.7rem; color:var(--walnut); font-weight:700; opacity:0.7; text-align:center; }

  .results-row { display:flex; justify-content:space-between; width:100%; font-size:0.9rem; font-weight:800; color:var(--walnut); border-bottom:2px dashed #e0c898; padding:3px 0; }
  .results-row span { color:var(--carrot); }

  /* ── Badge UI ── */
  .badge-section-title {
    font-family:'Fredoka One',cursive; font-size:1rem;
    color:var(--walnut); text-align:left; width:100%;
    border-bottom:2px solid #e8c87a; padding-bottom:3px;
  }

  .badge-grid {
    display:grid; grid-template-columns:repeat(4,1fr);
    gap:6px; width:100%;
  }

  .badge-item {
    display:flex; flex-direction:column; align-items:center;
    gap:2px; text-align:center;
  }

  .badge-circle {
    width:54px; height:54px; border-radius:50%;
    display:flex; align-items:center; justify-content:center;
    font-size:1.6rem; border:3px solid;
    position:relative; transition:transform 0.2s;
    box-shadow:0 3px 8px rgba(0,0,0,0.15);
  }
  .badge-circle:hover { transform:scale(1.1); }

  .badge-circle.locked {
    background:#e8dcc8; border-color:#c0a878;
    filter:grayscale(1); opacity:0.5;
  }
  .badge-circle.unlocked {
    background: linear-gradient(135deg,#fff8ee,#ffe8b0);
    border-color: var(--carrot);
  }
  .badge-circle.unlocked::after {
    content:'✓'; position:absolute; bottom:-2px; right:-2px;
    background:var(--green); color:#fff; border-radius:50%;
    width:18px; height:18px; font-size:0.6rem;
    display:flex; align-items:center; justify-content:center;
    font-weight:900; border:2px solid #fff;
  }

  /* tier colours */
  .badge-circle.tier-bronze.unlocked { background:linear-gradient(135deg,#f5deb3,#cd853f); border-color:#8b6914; }
  .badge-circle.tier-silver.unlocked { background:linear-gradient(135deg,#e8e8e8,#b0b0b0); border-color:#808080; }
  .badge-circle.tier-gold.unlocked   { background:linear-gradient(135deg,#fff176,#ffd700); border-color:#b8860b; }
  .badge-circle.tier-legend.unlocked { background:linear-gradient(135deg,#e040fb,#ff6b35); border-color:#9c27b0; box-shadow:0 0 12px rgba(156,39,176,0.5); }

  .badge-name { font-size:0.58rem; font-weight:800; color:var(--walnut); line-height:1.2; }
  .badge-locked-name { font-size:0.58rem; font-weight:800; color:#b0a090; line-height:1.2; }
  .badge-desc-mini { font-size:0.5rem; color:var(--walnut); opacity:0.75; line-height:1.15; margin-top:1px; }

  /* new-badge pulse on recently unlocked */
  @keyframes badgePop {
    0%   { transform:scale(1); }
    40%  { transform:scale(1.25); }
    70%  { transform:scale(0.95); }
    100% { transform:scale(1); }
  }
  .badge-new { animation: badgePop 0.5s ease; }
  .easter-glow { border-color: #ff80ab !important; box-shadow: 3px 3px 0 #ff80ab, 0 0 12px rgba(255,128,171,0.4) !important; background: linear-gradient(135deg,#fff0f8,#ffe8b0) !important; }
  @keyframes easterPulse { 0%,100%{box-shadow:3px 3px 0 #ff80ab,0 0 8px rgba(255,128,171,0.3)} 50%{box-shadow:3px 3px 0 #ff80ab,0 0 20px rgba(255,128,171,0.7)} }
  .easter-glow { animation: easterPulse 2s infinite; }
  .mode-grid { max-height: 340px; overflow-y: auto; }

  /* ── Leaderboard ── */
  .lb-tabs { display:flex; gap:6px; width:100%; }
  .lb-tab {
    flex:1; font-family:'Fredoka One',cursive; font-size:0.78rem;
    background:var(--frosting); color:var(--walnut);
    border:2px solid var(--cake-brown); border-radius:12px;
    padding:4px 4px; cursor:pointer; text-align:center;
    box-shadow:2px 2px 0 var(--cake-brown); transition:transform 0.1s;
  }
  .lb-tab:hover { transform:translateY(-2px); }
  .lb-tab.active { background:var(--carrot); color:#fff; border-color:var(--carrot-dark); box-shadow:2px 2px 0 var(--carrot-dark); }

  .lb-table { width:100%; border-collapse:collapse; }
  .lb-table th {
    font-family:'Fredoka One',cursive; font-size:0.8rem;
    color:var(--walnut); text-align:left; padding:4px 6px;
    border-bottom:2px solid #e8c87a;
  }
  .lb-table td { font-size:0.82rem; font-weight:800; color:var(--walnut); padding:5px 6px; border-bottom:1px dashed #e8d8a0; }
  .lb-table tr:nth-child(1) td { color:var(--carrot-dark); background:rgba(255,215,0,0.15); }
  .lb-table tr:nth-child(2) td { background:rgba(192,192,192,0.12); }
  .lb-table tr:nth-child(3) td { background:rgba(205,127,50,0.10); }
  .lb-rank { font-family:'Fredoka One',cursive; font-size:1rem; }
  .lb-score { color:var(--carrot); }
  .lb-you { background:rgba(232,114,42,0.12) !important; }
  .lb-you td { color:var(--carrot-dark); }

  .lb-name-input {
    font-family:'Fredoka One',cursive; font-size:1rem;
    border:3px solid var(--cake-brown); border-radius:12px;
    padding:5px 12px; width:100%; background:var(--frosting);
    color:var(--walnut); outline:none; cursor:text;
  }
  .lb-name-input:focus { border-color:var(--carrot); }

  .lb-status { font-size:0.78rem; color:var(--walnut); font-weight:700; opacity:0.7; text-align:center; min-height:18px; }
  .lb-empty  { font-size:0.9rem; color:var(--walnut); opacity:0.5; text-align:center; padding:16px 0; }
</style>
</head>
<body>

<h1>🥕 Carrot Cake Catcher</h1>

<div id="top-nav">
  <button class="nav-btn active" id="btn-play">🎮 Play</button>
  <button class="nav-btn" id="btn-badges">🏅 Badges</button>
  <button class="nav-btn" id="btn-lb">🌍 Board</button>
  <button class="nav-btn" id="btn-drive">🚗 Drive</button>
  <button class="nav-btn" id="btn-bake">🎂 Bake</button>
  <button class="nav-btn" id="btn-tycoon">🏭 Tycoon</button>
  <button class="nav-btn" id="btn-2p">👥 2P</button>
  <button class="nav-btn" id="btn-clicker">🥕 Clicker</button>
  <button class="nav-btn" id="btn-shop">🍰 Shop</button>
  <button class="nav-btn" id="btn-admin">🛠️ Admin</button>
  <button class="nav-btn" id="btn-cookbook">📖 Cookbook</button>
  <button class="nav-btn" id="btn-stats">📊 Stats</button>
  <button class="nav-btn" id="btn-changelog">📋 Updates</button>
</div>

<div id="hud">
  <div class="hud-box">Score: <span id="score-val">0</span></div>
  <div class="hud-box">❤️ <span id="lives-val">3</span></div>
  <div class="hud-box">Best: <span id="best-val">0</span></div>
  <div class="hud-box" id="mode-badge">Classic</div>
</div>

<div id="game-area">
  <div id="level-badge">Lv <span id="lv-val">1</span></div>
  <div id="baker-lvl-badge" style="position:absolute;top:8px;left:8px;z-index:5;background:rgba(255,255,255,0.85);border-radius:12px;padding:3px 9px;font-weight:800;font-size:0.75rem;color:#c45a18;">⭐ Lv1</div>
  <div id="holiday-banner" style="display:none;position:absolute;top:34px;left:50%;transform:translateX(-50%);z-index:5;padding:4px 12px;border-radius:12px;font-weight:800;font-size:0.75rem;color:#fff;text-shadow:1px 1px 2px rgba(0,0,0,0.4);"></div>
  <div id="mute-toggle-btn" onclick="toggleMute()" style="position:absolute;top:8px;right:44px;z-index:5;background:rgba(255,255,255,0.85);border-radius:12px;padding:3px 9px;font-weight:800;font-size:0.9rem;cursor:pointer;">🔊</div>
  <div id="dark-toggle-btn" onclick="toggleDarkMode()" style="position:absolute;top:8px;right:8px;z-index:5;background:rgba(255,255,255,0.85);border-radius:12px;padding:3px 9px;font-weight:800;font-size:0.9rem;cursor:pointer;">🌙</div>
  <div id="timer-bar-wrap"><div id="timer-bar"></div></div>
  <div id="combo-display">🔥 x2</div>
  <div id="particles-container"></div>
  <div id="powerup-msg">🌀 Basket shrunk!</div>

  <div id="basket">
    <svg id="basket-svg" width="80" height="54" viewBox="0 0 80 54" fill="none">
      <rect x="2" y="22" width="76" height="26" rx="6" fill="#a06b3c"/>
      <rect x="2" y="22" width="76" height="8"  rx="4" fill="#7a4e28"/>
      <rect x="2" y="8"  width="76" height="18" rx="5" fill="#fdf6e3"/>
      <ellipse cx="40" cy="9" rx="37" ry="10" fill="#fdf6e3"/>
      <text x="30" y="19" font-size="17" text-anchor="middle">🥕</text>
      <text x="50" y="19" font-size="17" text-anchor="middle">🥕</text>
      <rect x="2" y="8" width="76" height="40" rx="6" stroke="#8a5530" stroke-width="3" fill="none"/>
    </svg>
  </div>

  <div id="score-popup">+10</div>

  <!-- Badge unlock toast -->
  <div id="badge-toast">
    <div class="toast-icon" id="toast-icon">🏅</div>
    <div class="toast-text">
      <div class="toast-title">Badge Unlocked!</div>
      <div class="toast-name" id="toast-name">First Bite</div>
    </div>
  </div>

  <!-- Name prompt (first launch) -->
  <div id="name-prompt" style="display:none;position:absolute;inset:0;background:rgba(255,240,200,0.98);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:14px;z-index:60;border-radius:20px;padding:20px;">
    <div style="font-size:3rem;animation:bounce 0.7s infinite alternate">🥕</div>
    <h2 style="font-family:'Fredoka One',cursive;color:var(--carrot-dark);font-size:1.8rem;text-shadow:3px 3px 0 #f5e6c8">Welcome, Baker!</h2>
    <p style="font-weight:700;color:var(--walnut);text-align:center;font-size:0.9rem">Enter your name for the 🌍 Leaderboard</p>
    <input id="welcome-name" type="text" maxlength="16" placeholder="Your name…" style="font-family:'Fredoka One',cursive;font-size:1rem;border:3px solid var(--carrot);border-radius:12px;padding:7px 14px;width:100%;background:var(--frosting);color:var(--walnut);outline:none;cursor:text;">
    <button class="play-btn" id="welcome-go-btn">🍰 Let's Bake!</button>
    <button class="small-btn" id="welcome-skip-btn">Skip for now</button>
  </div>

  <!-- Main overlay -->
  <div id="overlay">
    <div class="big-emoji">🎂</div>
    <h2>Carrot Cake Catcher</h2>
    <div class="mode-grid" id="main-mode-grid">
