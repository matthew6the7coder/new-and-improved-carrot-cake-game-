        body: `A ${format.toLowerCase()} built around ${flavor.toLowerCase()}. ${COOKBOOK_NOTES[i % COOKBOOK_NOTES.length]}`,
        kind:'recipe'
      });
      i++;
    });
  });
  return pages;
}
