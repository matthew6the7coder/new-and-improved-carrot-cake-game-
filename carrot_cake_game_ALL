  const rows = await fetchLeaderboard(lbMode);
  if (!lbPanelEl) return;
  status.textContent = rows.length ? `Top ${rows.length} players` : 'No scores yet — be the first!';

  if (!rows.length) { content.innerHTML='<div class="lb-empty">🌱 No scores yet! Play and submit yours.</div>'; return; }

  const myName = playerName.toLowerCase();
  content.innerHTML = `
    <table class="lb-table">
      <thead><tr><th>#</th><th>Player</th><th>Score</th><th>Date</th></tr></thead>
      <tbody>
        ${rows.map((r,i)=>`
