// ── 4) Daily login streak bonus ──────────────────────────────────────────
function checkDailyStreak(){
  const today = new Date().toDateString();
  const last = localStorage.getItem('ccc_last_login');
  if(last === today) return;
  const yesterday = new Date(Date.now()-86400000).toDateString();
  let streak = parseInt(localStorage.getItem('ccc_streak'))||0;
  streak = (last===yesterday) ? streak+1 : 1;
  localStorage.setItem('ccc_last_login', today);
  localStorage.setItem('ccc_streak', streak);
  const bonus = Math.min(streak,7)*5;
  wins += bonus; saveShopData(); updateShopUI();
  setTimeout(()=>{
    showPopup(`🔥 Day ${streak} streak! +${bonus} 🏆`, AREA_W()/2-70, 100, false);
    playLevelUpSound();
  }, 700);
}
checkDailyStreak();

