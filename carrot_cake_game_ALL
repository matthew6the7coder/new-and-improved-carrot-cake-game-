const _origUpdateBasket = updateBasket;
updateBasket = function(){ _origUpdateBasket(); applyScreenShake(); };

const _origStartGame = startGame;
startGame = function(){
  _origStartGame();
  applyBasketCosmetics();
  showHolidayBanner();
};

const _origEndGame = endGame;
endGame = function(){
  awardWinsForGame(score);
  _origEndGame();
};

// Wrap the collision-scoring branch by patching loop indirectly:
// updateCombo already runs each good/bad catch — hook XP + shake there.
const _origUpdateCombo = updateCombo;
updateCombo = function(good){
  _origUpdateCombo(good);
  if(good){
    gainXP(5);
    if(combo>=3) triggerScreenShake(8, Math.min(combo*1.2, 12));
    playCatchSound();
  } else {
    playBadCatchSound();
  }
};

// Apply holiday point multiplier by wrapping comboMult (used to compute pts)
const _origComboMult = comboMult;
comboMult = function(){
  const base=_origComboMult();
  const holiday = (typeof forcedHoliday !== 'undefined' && forcedHoliday) ? forcedHoliday : activeHoliday;
  return holiday ? +(base*holiday.mult).toFixed(2) : base;
};

