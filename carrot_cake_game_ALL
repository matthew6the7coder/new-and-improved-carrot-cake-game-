        <div style="text-align:center">
          <div class="badge-circle tier-${b.tier} unlocked badge-new">${b.icon}</div>
          <div class="badge-name">${b.name}</div>
        </div>`).join('')}
    </div>`:''}
    <button class="play-btn" id="play-again-btn">🔄 Play Again</button>
