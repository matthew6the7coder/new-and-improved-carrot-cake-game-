// Submit to leaderboard on game end if score is good
async function maybeSubmitScore(mode, score) {
  if (!playerName || score <= 0) return;
  const existing = getStoredLbParsed(mode);
  const minScore = existing.length >= 10 ? existing[existing.length-1]?.score || 0 : 0;
  if (score > minScore || existing.length < 10) {
    await submitScore(mode, playerName, score);
  }
}

