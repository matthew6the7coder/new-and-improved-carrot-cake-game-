// ── Combo screen shake ───────────────────────────────────────────────────
let shakeFrames=0, shakeMag=0;
function triggerScreenShake(frames, magnitude){ shakeFrames=frames; shakeMag=magnitude; }
function applyScreenShake(){
  if(shakeFrames>0){
    const dx=(Math.random()-0.5)*shakeMag, dy=(Math.random()-0.5)*shakeMag;
    gameArea.style.transform=`translate(${dx.toFixed(1)}px,${dy.toFixed(1)}px)`;
    shakeFrames--;
    if(shakeFrames===0) gameArea.style.transform='';
  }
}

// ── Holiday events ───────────────────────────────────────────────────────
function getActiveHolidayEvent(){
  const d=new Date(), m=d.getMonth()+1, day=d.getDate();
  if(m===1 && day===1)                 return {name:'New Year Bash',        color:'#caa000', mult:2};
  if(m===2 && day===14)                return {name:"Valentine's Sweetness",color:'#c2377e', mult:1.5};
  if(m===3 && day===17)                return {name:"St. Paddy's Luck",     color:'#1e8a1e', mult:1.5};
  if(m===10 && day===31)               return {name:'Spooky Night',         color:'#c56d00', mult:2};
  if(m===11 && day>=22 && day<=28)     return {name:'Thanksgiving Feast',   color:'#8B4513', mult:1.5};
  if(m===12 && (day===24||day===25))   return {name:'Festive Winter',       color:'#c22',    mult:3};
  return null;
}
const activeHoliday = getActiveHolidayEvent();
function showHolidayBanner(){
  const holiday = (typeof forcedHoliday !== 'undefined' && forcedHoliday) ? forcedHoliday : activeHoliday;
  const b=document.getElementById('holiday-banner');
  if(!holiday){ b.style.display='none'; return; }
  b.style.display='block';
  b.style.background=holiday.color;
  b.textContent=`🎉 ${holiday.name} — x${holiday.mult} points!`;
  let seen = JSON.parse(localStorage.getItem('ccc_holidays')||'[]');
  if(!seen.includes(holiday.name)){
    seen.push(holiday.name);
    localStorage.setItem('ccc_holidays', JSON.stringify(seen));
  }
}

