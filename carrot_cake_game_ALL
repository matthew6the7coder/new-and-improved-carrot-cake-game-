// ── 1) Lightweight sound effects (Web Audio API, no external files) ─────
let soundMuted = localStorage.getItem('ccc_muted') === '1';
let _audioCtx = null;
function getAudioCtx(){
  if(!_audioCtx) _audioCtx = new (window.AudioContext||window.webkitAudioContext)();
  return _audioCtx;
}
function beep(freq, duration, type, vol){
  if(soundMuted) return;
  try{
    const ctx=getAudioCtx();
    const osc=ctx.createOscillator(), gain=ctx.createGain();
    osc.type=type||'sine'; osc.frequency.value=freq;
    gain.gain.value=vol||0.12;
    osc.connect(gain); gain.connect(ctx.destination);
    osc.start();
    gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime+duration);
    osc.stop(ctx.currentTime+duration);
  }catch(e){}
}
function playCatchSound(){ beep(700,0.07,'triangle',0.1); }
function playBadCatchSound(){ beep(140,0.14,'sawtooth',0.1); }
function playGoldenSound(){ beep(900,0.09,'triangle',0.14); setTimeout(()=>beep(1300,0.14,'triangle',0.14),80); }
function playBadgeSound(){ beep(600,0.09,'sine',0.14); setTimeout(()=>beep(950,0.14,'sine',0.14),100); }
function playLevelUpSound(){ beep(500,0.09,'sine',0.12); setTimeout(()=>beep(760,0.14,'sine',0.12),100); }
function toggleMute(){
  soundMuted=!soundMuted;
  localStorage.setItem('ccc_muted', soundMuted?'1':'0');
  updateMuteBtn();
  if(!soundMuted) beep(700,0.07,'triangle',0.1);
}
function updateMuteBtn(){
  const b=document.getElementById('mute-toggle-btn');
