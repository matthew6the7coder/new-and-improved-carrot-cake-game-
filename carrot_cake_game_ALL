  saveShopData();
}

// ── AFK Lounge ───────────────────────────────────────────────────────────
let isAFK=false, afkTimeLeft=0, afkTimer=null;
function getAFKDuration(){ return Math.max(10, 60 - afkUpgradeLvl*10); }
function updateAFKUI(){
  const t=document.getElementById('afk-time-left');
  if(t) t.textContent = `${Math.floor(afkTimeLeft/60)}:${String(afkTimeLeft%60).padStart(2,'0')}`;
  const btn=document.getElementById('afk-toggle-btn');
  if(btn) btn.textContent = isAFK ? '🏃 Exit AFK Lounge' : '🛋️ Enter AFK Lounge (Earn 10 🏆)';
}
function toggleAFK(){
  isAFK=!isAFK;
  if(isAFK){
    afkTimeLeft=getAFKDuration();
    afkTimer=setInterval(()=>{
      afkTimeLeft--;
      if(afkTimeLeft<=0){
        wins+=10; saveShopData(); updateShopUI();
        afkTimeLeft=getAFKDuration();
      }
      updateAFKUI();
    },1000);
  } else {
    clearInterval(afkTimer); afkTimer=null;
  }
  updateAFKUI();
}
function buyAFKUpgrade(){
  const cost=(afkUpgradeLvl+1)*3;
  if(afkUpgradeLvl<5 && wins>=cost){
    wins-=cost; afkUpgradeLvl++; saveShopData(); updateShopUI(); updateAFKUI();
  }
}

