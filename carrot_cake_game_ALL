async function fetchLeaderboard(mode) {
  try {
    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({
        model:'claude-sonnet-4-20250514',
        max_tokens:800,
        system:`You are a leaderboard database. You manage a global leaderboard for the game "Carrot Cake Catcher".
When asked to GET scores for a mode, respond ONLY with a JSON array of up to 10 objects: [{name,score,date}] sorted by score descending. If no scores exist return [].
When asked to SUBMIT a score, merge it into the existing list, keep only top 10 by score, and respond with the updated JSON array.
Store data mentally — you will be given the current leaderboard state in each request. Respond ONLY with valid JSON, no markdown.`,
        messages:[{role:'user', content:`GET leaderboard for mode: ${mode}. Current stored data: ${getStoredLb(mode)}`}]
      })
    });
    const data = await res.json();
    const text = data.content?.map(c=>c.text||'').join('') || '[]';
    return JSON.parse(text.replace(/```json|```/g,'').trim());
  } catch(e) { return getStoredLbParsed(mode); }
}

async function submitScore(mode, name, score) {
  const current = getStoredLb(mode);
  try {
    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({
        model:'claude-sonnet-4-20250514',
        max_tokens:800,
        system:`You are a leaderboard database for "Carrot Cake Catcher". When given a SUBMIT request, add the new score to the list, sort by score descending, keep only top 10, and respond ONLY with the updated JSON array [{name,score,date}]. No markdown, no explanation.`,
        messages:[{role:'user', content:`SUBMIT score for mode: ${mode}. New entry: {name:"${name}",score:${score},date:"${new Date().toLocaleDateString()}"}. Current leaderboard: ${current}`}]
      })
    });
    const data = await res.json();
    const text = data.content?.map(c=>c.text||'').join('') || current;
    const parsed = JSON.parse(text.replace(/```json|```/g,'').trim());
    saveLb(mode, parsed);
    return parsed;
  } catch(e) {
    // Fallback: store locally
    const arr = getStoredLbParsed(mode);
    arr.push({name, score, date: new Date().toLocaleDateString()});
    arr.sort((a,b)=>b.score-a.score);
    const top10 = arr.slice(0,10);
    saveLb(mode, top10);
    return top10;
  }
}

function getStoredLb(mode) {
  try { return localStorage.getItem('ccc_lb_'+mode) || '[]'; } catch(e){ return '[]'; }
}
function getStoredLbParsed(mode) {
  try { return JSON.parse(getStoredLb(mode)); } catch(e){ return []; }
}
function saveLb(mode, arr) {
  try { localStorage.setItem('ccc_lb_'+mode, JSON.stringify(arr)); } catch(e){}
}

